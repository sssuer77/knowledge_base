            ]
        },
        {
            "type": "title",
            "content": {
                "title_content": [
                    {
                        "type": "text",
                        "content": "说明"
                    }
                ],
                "level": 1
            },
            "bbox": [
                188,
                298,
                225,
                313
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "如下配置仅供参考，运营商可根据实际情况进行调整。"
                    }
                ]
            },
            "bbox": [
                142,
                324,
                559,
                339
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(1) 创建业务 VLAN"
                    }
                ]
            },
            "bbox": [
                142,
                374,
                312,
                389
            ]
        },
        {
            "type": "code",
            "content": {
                "code_caption": [],
                "code_content": [
                    {
                        "type": "text",
                        "content": "<AC>system-view\n[AC]vlan 2\n[AC-vlan2] quit "
                    }
                ],
                "code_language": "txt"
            },
            "bbox": [
                142,
                397,
                277,
                442
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(2) 创建 WLAN-ESS 接口并加入业务 VLAN"
                    }
                ]
            },
            "bbox": [
                142,
                447,
                500,
                461
            ]
        },
        {
            "type": "code",
            "content": {
                "code_caption": [],
                "code_content": [
                    {
                        "type": "text",
                        "content": "[AC]interface WLAN-ESS 1\n[AC-WLAN-ESS1]port access vlan 2\n[AC-WLAN-ESS1]quit "
                    }
                ],
                "code_language": "txt"
            },
            "bbox": [
                144,
                471,
                421,
                516
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(3) 配置明文方式的服务模板"
                    }
                ]
            },
            "bbox": [
                142,
                521,
                384,
                536
            ]
        },
        {
            "type": "code",
            "content": {
                "code_caption": [],
                "code_content": [
                    {
                        "type": "text",
                        "content": "[AC]wlan service-template 1 clear\n[AC-wlan-st-1]ssid ssidh3c\n[AC-wlan-st-1]bind WLAN-ESS 1\n[AC-wlan-st-1]service-template enable\nPlease wait... Done.\n[AC-wlan-st-1]quit "
                    }
                ],
                "code_language": "txt"
            },
            "bbox": [
                144,
                543,
                465,
                638
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(4) 开启自动 AP 功能"
                    }
                ]
            },
            "bbox": [
                142,
                644,
                329,
                659
            ]
        },
        {
            "type": "code",
            "content": {
                "code_caption": [],
                "code_content": [
                    {
                        "type": "text",
                        "content": "[AC]wlan auto-ap enable\n[AC]wlan ap 2608 model LA2608 id 1\n[AC-wlan-ap-2608]serial-id auto\n[AC-wlan-ap-2608]radio 1\n[AC-wlan-ap-2608-radio-1]service-template 1\n[AC-wlan-ap-2608-radio-1]radio enable\n[AC-wlan-ap-2608-radio-1]quit\n[AC-wlan-ap-2608]quit "
                    }
                ],
                "code_language": "txt"
            },
            "bbox": [
                144,
                667,
                515,
                796
            ]
        },
        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "(5) 配置 VLAN 接口 IP 地址"
                    }
                ]
            },
            "bbox": [
                142,
                800,
                376,
                815
            ]
        },
        {
            "type": "code",
            "content": {
                "code_caption": [],
                "code_content": [
                    {
                        "type": "text",
                        "content": "[AC]interface Vlan-interface 1\n[AC-Vlan-interface1]ip address 60.191.99.143 255.255.0.0\n[AC-Vlan-interface1]quit\n[AC]interface Vlan-interface 2\n[AC-Vlan-interface2]ip address 10.249.136.1 255.255.252.0\n[AC-Vlan-interface2]quit "
                    }
                ],
                "code_language": "ini"
            },
            "bbox": [
                144,
                824,
                635,
                919
            ]
        },
        {
